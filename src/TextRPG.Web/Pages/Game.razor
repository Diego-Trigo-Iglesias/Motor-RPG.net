@page "/"
@using TextRPG.Core.Enums
@using TextRPG.Core.Models
@using TextRPG.Core.Engine
@using TextRPG.Web.Rendering
@using TextRPG.Core.PixelArt
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="game-container">
    <div class="canvas-wrapper">
        <canvas id="gameCanvas" width="800" height="450"
                style="width:100%;max-width:1200px;image-rendering:pixelated;background:#0a0e1e;"></canvas>
    </div>

    @* Title screen *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Title)
    {
        <div class="menu-overlay">
            <button class="menu-btn start-btn" @onclick="DoStartNewGame">Iniciar Aventura</button>
        </div>
    }

    @* Character creation *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.CreateCharacter)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title">Crea tu personaje</div>
                <input class="game-input" @bind="_heroName" placeholder="Nombre del heroe" />
                <div class="class-list">
                    <button class="menu-btn class-btn warrior-btn" @onclick="() => DoCreateCharacter(CharacterClass.Warrior)">[1] Guerrero - Tanque y resistencia</button>
                    <button class="menu-btn class-btn mage-btn" @onclick="() => DoCreateCharacter(CharacterClass.Mage)">[2] Mago - Alto dano, fragil</button>
                    <button class="menu-btn class-btn rogue-btn" @onclick="() => DoCreateCharacter(CharacterClass.Rogue)">[3] Picaro - Equilibrado, evasion</button>
                </div>
            </div>
        </div>
    }

    @* Main menu *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.MainMenu)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                @if (_currentLocation?.HasEnemies ?? false)
                {
                    <button class="menu-btn" @onclick="DoExplore">[1] Explorar</button>
                }
                <button class="menu-btn" @onclick="ShowTravelMenu">[2] Viajar</button>
                @if (_currentLocation?.HasShop ?? false)
                {
                    <button class="menu-btn" @onclick="ShowShop">[3] Tienda</button>
                }
                @if (_currentLocation?.HasHealer ?? false)
                {
                    <button class="menu-btn" @onclick="DoHeal">[4] Curandero (30 oro)</button>
                }
                <button class="menu-btn" @onclick="ShowInventory">[5] Inventario</button>
            </div>
        </div>
    }

    @* Travel *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Travel)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title">Viajar</div>
                @{
                    int i = 1;
                    foreach (var loc in World.Locations.Where(l => l.Id != Renderer.LocationId))
                    {
                        <button class="menu-btn" @onclick="() => DoTravelTo(loc.Id)">[@(i++)] @loc.Name</button>
                    }
                }
                <button class="menu-btn" @onclick="BackToMain">[B] Volver</button>
            </div>
        </div>
    }

    @* Shop *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Shop)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title">Tienda (Oro: @GetPlayerGold())</div>
                <button class="menu-btn" @onclick="() => DoBuyItem(0)">[1] Pocion pequena (10 oro) +30HP</button>
                <button class="menu-btn" @onclick="() => DoBuyItem(1)">[2] Pocion grande (25 oro) +70HP</button>
                <button class="menu-btn" @onclick="() => DoBuyItem(2)">[3] Amuleto fuerza (50 oro) +5ATK</button>
                <button class="menu-btn" @onclick="() => DoBuyItem(3)">[4] Armadura ligera (40 oro) +3DEF</button>
                <button class="menu-btn" @onclick="BackToMain">[B] Salir</button>
            </div>
        </div>
    }

    @* Combat *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Combat)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <button class="menu-btn fight-btn" @onclick="DoAttack">[1] Atacar</button>
                <button class="menu-btn" @onclick="DoFlee">[2] Huir</button>
            </div>
        </div>
    }

    @* Victory *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Victory)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title victory-text">Victoria!</div>
                <button class="menu-btn" @onclick="DoContinueAfterBattle">[Enter] Continuar</button>
            </div>
        </div>
    }

    @* Defeat *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Defeat)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title defeat-text">Derrota...</div>
                <button class="menu-btn" @onclick="DoRestartGame">[Enter] Volver al inicio</button>
            </div>
        </div>
    }

    @* Inventory *@
    @if (Renderer.CurrentScreen == WebRenderer.Screen.Inventory)
    {
        <div class="menu-overlay">
            <div class="menu-box">
                <div class="menu-title">Inventario</div>
                @if (GetPlayerInventory().Count > 0)
                {
                    foreach (var item in GetPlayerInventory())
                    {
                        <div class="inventory-item">- @item</div>
                    }
                }
                else
                {
                    <div class="inventory-item">(vacio)</div>
                }
                <button class="menu-btn" @onclick="BackToMain">[Enter] Volver</button>
            </div>
        </div>
    }
</div>

@code {
    private WebRenderer Renderer { get; set; } = new();
    private GameState? _state;
    private Player? _player => _state?.Player;
    private Location? _currentLocation;
    private Enemy? _currentEnemy;
    private readonly CombatEngine _combat = new();
    private string _heroName = "Heroe";

    private static readonly (string Name, int Price, Action<Player> Apply)[] ShopItems =
    [
        ("Pocion pequena", 10, p => p.Heal(30)),
        ("Pocion grande", 25, p => p.Heal(70)),
        ("Amuleto de fuerza", 50, p => p.Attack += 5),
        ("Armadura ligera", 40, p => p.Defense += 3),
    ];

    private int GetPlayerGold() => _player?.Gold ?? 0;
    private List<string> GetPlayerInventory() => _player?.Inventory ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("TextRPG.Renderer.init", "gameCanvas", 2);
        }
        await PushRenderState();
    }

    private async Task PushRenderState()
    {
        try
        {
            var state = Renderer.GetRenderState(_player, _currentEnemy, _state);
            await JS.InvokeVoidAsync("TextRPG.Renderer.pushState", state);
        }
        catch { }
    }

    private async Task DoStartNewGame()
    {
        Renderer.Clear();
        Renderer.SetScreen(WebRenderer.Screen.CreateCharacter);
        _heroName = "";
        await PushRenderState();
    }

    private async Task DoCreateCharacter(CharacterClass cls)
    {
        var name = string.IsNullOrWhiteSpace(_heroName) ? "Heroe" : _heroName;
        _state = new GameState { Player = Player.Create(name, cls) };
        _state.CurrentLocationId = "village";
        _currentLocation = _state.CurrentLocation;
        Renderer.PlayClassSelectionAnimation(cls);
        Renderer.Clear();
        Renderer.PrintStatus(_state.Player);
        Renderer.PrintLocation(_state.CurrentLocation);
        Renderer.SetScreen(WebRenderer.Screen.MainMenu);
        await PushRenderState();
    }

    private async Task DoExplore()
    {
        _currentEnemy = Enemy.Random(_state!.Player.Level);
        _state.TotalBattles++;
        Renderer.PrintCombatHeader(_state.Player, _currentEnemy);
        await PushRenderState();
    }

    private async Task DoAttack()
    {
        if (_state == null || _currentEnemy == null) return;
        var round = _combat.SimulateRound(_state.Player, _currentEnemy);
        _combat.ApplyRound(_state.Player, _currentEnemy, round);
        Renderer.PrintCombatRound(_state.Player, _currentEnemy, round, Renderer.LastRoundNum + 1);

        if (!_currentEnemy.IsAlive)
        {
            _state.TotalVictories++;
            var enemy = _currentEnemy;
            _state.Player.Gold += enemy.GoldReward;
            _state.Player.GainExperience(enemy.ExpReward);
            var prevLevel = _state.Player.Level;
            Renderer.PrintVictory(enemy, enemy.ExpReward, enemy.GoldReward);
            if (_state.Player.Level > prevLevel)
                Renderer.PrintLevelUp(_state.Player);
        }
        else if (!_state.Player.IsAlive)
        {
            Renderer.PrintDefeat();
        }
        await PushRenderState();
    }

    private async Task DoFlee()
    {
        Renderer.MarkupLine("Huyes del combate!");
        _currentEnemy = null;
        Renderer.Clear();
        Renderer.PrintStatus(_state!.Player);
        Renderer.PrintLocation(_state.CurrentLocation);
        Renderer.SetScreen(WebRenderer.Screen.MainMenu);
        await PushRenderState();
    }

    private async Task DoContinueAfterBattle()
    {
        _currentEnemy = null;
        Renderer.Clear();
        Renderer.PrintStatus(_state!.Player);
        Renderer.PrintLocation(_state.CurrentLocation);
        Renderer.SetScreen(WebRenderer.Screen.MainMenu);
        await PushRenderState();
    }

    private void ShowTravelMenu()
    {
        Renderer.SetScreen(WebRenderer.Screen.Travel);
    }

    private async Task DoTravelTo(string destId)
    {
        _state!.CurrentLocationId = destId;
        _currentLocation = _state.CurrentLocation;
        Renderer.PlayTravelAnimation(Renderer.LocationId, destId);
        Renderer.Clear();
        Renderer.PrintStatus(_state.Player);
        Renderer.PrintLocation(_state.CurrentLocation);
        Renderer.SetScreen(WebRenderer.Screen.MainMenu);
        await PushRenderState();
    }

    private void ShowShop()
    {
        Renderer.SetScreen(WebRenderer.Screen.Shop);
    }

    private async Task DoBuyItem(int index)
    {
        if (_player == null || index < 0 || index >= ShopItems.Length) return;
        var (name, price, apply) = ShopItems[index];
        if (_player.Gold < price)
        {
            Renderer.MarkupLine("No tienes suficiente oro.");
            return;
        }
        _player.Gold -= price;
        apply(_player);
        _player.Inventory.Add(name);
        Renderer.MarkupLine($"Has comprado: {name}");
        Renderer.PlayHealAnimation();
        await PushRenderState();
    }

    private async Task DoHeal()
    {
        if (_player!.Gold < 30)
        {
            Renderer.MarkupLine("Necesitas 30 oro.");
            return;
        }
        _player.Gold -= 30;
        _player.Heal(_player.MaxHp);
        Renderer.PlayHealAnimation();
        Renderer.MarkupLine("HP completamente restaurado.");
        await PushRenderState();
    }

    private void ShowInventory()
    {
        Renderer.WritePlayerStats(_state!.Player, _state);
        Renderer.SetScreen(WebRenderer.Screen.Inventory);
    }

    private void BackToMain()
    {
        Renderer.Clear();
        if (_state != null)
        {
            Renderer.PrintStatus(_state.Player);
            Renderer.PrintLocation(_state.CurrentLocation);
        }
        Renderer.SetScreen(_state != null ? WebRenderer.Screen.MainMenu : WebRenderer.Screen.Title);
    }

    private void DoRestartGame()
    {
        _state = null;
        _currentEnemy = null;
        Renderer.Clear();
        Renderer.PrintTitle();
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}